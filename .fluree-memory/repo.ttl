    mem:factKind "architecture" .

mem:fact-01kms14fmrfc9ypprawdjg4g35 a mem:Fact ;
    mem:content "V3 object-to-Binding conversion in `fluree-db-query` is now centralized in `src/v3_binding.rs`. Use `late_materialized_object_binding(...)` for the fast encoded-path mapping from `(o_type,o_key,p_id,t,o_i)` and `materialized_object_binding(...)` for wrapping decoded `FlakeValue`s with the correct `Binding::Sid`/`Binding::Lit` shape and datatype metadata. `binary_scan.rs` and `join.rs` both rely on this helper so blank-node, string/json/vector/NUM_BIG, and literal datatype handling stay aligned." ;
    mem:tag "binding" ;
    mem:tag "cleanup" ;
    mem:tag "join" ;
    mem:tag "maintainability" ;
    mem:tag "query" ;
    mem:tag "v3" ;
    mem:scope mem:repo ;
