mem:decision-01kkmfs0sktrfn7ny36wzmwv9n a mem:Decision ;
    mem:content "Added RDF/XML output for SPARQL CONSTRUCT/DESCRIBE via API `FormatterConfig::rdf_xml()` + server `Accept: application/rdf+xml`. Implementation uses construct template instantiation into `fluree_graph_ir::Graph` (shared helper `instantiate_construct_graph`) and a minimal RDF/XML serializer that requires predicate IRIs to be QName-splittable (last '#' or '/' and NCName local). Server rejects RDF/XML for SELECT/ASK, tracked, proxy-mode, and identity-scoped SPARQL paths; supports it for ledger-scoped SPARQL, including dataset-clause queries." ;
    mem:tag "accept" ;
    mem:tag "construct" ;
    mem:tag "describe" ;
    mem:tag "formatting" ;
    mem:tag "rdfxml" ;
    mem:tag "server" ;
    mem:tag "sparql" ;
    mem:scope mem:repo ;
    mem:sensitivity "public" ;
    mem:artifactRef "docs/api/headers.md" ;
    mem:artifactRef "fluree-db-api/src/format/config.rs" ;
    mem:artifactRef "fluree-db-api/src/format/construct.rs" ;
    mem:artifactRef "fluree-db-api/src/format/rdf_xml.rs" ;
    mem:artifactRef "fluree-db-server/src/extract/headers.rs" ;
    mem:artifactRef "fluree-db-server/src/routes/query.rs" ;
    mem:createdAt "2026-03-13T20:56:28.723996+00:00"^^xsd:dateTime ;
    mem:rationale "BSBM testdriver requests RDF/XML for DESCRIBE. Implementing a full general RDF/XML QName mapping is complex; current serializer targets typical benchmark IRIs with safe local names and fails fast otherwise." .

mem:fact-01kkp0yq2pef5qjn1nt8zvb19b a mem:Fact ;
    mem:content "Explain plans: CLI and HTTP now support SPARQL explain.\n\n- CLI: `fluree query --explain --sparql ...` (and JSON-LD) prints the plan as JSON without executing.\n- Server: added `/v1/fluree/explain/<ledger...>` supporting `application/json` (JSON-LD) and `application/sparql-query` (SPARQL). Root `/v1/fluree/explain` also accepts SPARQL when ledger can be determined via `fluree-ledger` header or a single `FROM <ledger>`.\n- Docs updated to use `/v1/fluree/explain` (no `X-Fluree-Explain` header)." ;
    mem:tag "cli" ;
    mem:tag "docs" ;
    mem:tag "explain" ;
    mem:tag "jsonld" ;
    mem:tag "server" ;
    mem:tag "sparql" ;
