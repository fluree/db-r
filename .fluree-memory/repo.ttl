    mem:factKind "architecture" .

mem:fact-01kms1m18azvc24qf6nc0f0tga a mem:Fact ;
    mem:content "High-volume remote-query tracing was trimmed to reduce CloudWatch/X-Ray blowups: removed per-range `binary_range_fetch` span/debug events, per-leaf header-directory fetch span/debug events, per-leaflet cache/load spans, and extra batched-join phase spans. Kept only coarse summary debug events like hot remote leaf promotion, first-time remote range leaf opens, and batched join completion summaries." ;
    mem:tag "binary-index" ;
    mem:tag "join" ;
    mem:tag "logging" ;
    mem:tag "query-perf" ;
    mem:tag "tracing" ;
    mem:tag "xray" ;
