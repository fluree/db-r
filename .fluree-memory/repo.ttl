    mem:createdAt "2026-02-26T22:01:47.686885+00:00"^^xsd:dateTime ;
    mem:artifactKind "module" .

mem:artifact-01kjte32vm4nfdfmxwvka0nqze a mem:Artifact ;
    mem:content "SPARQL Compliance Key Files Quick Reference\n\nTest infrastructure:\n- testsuite-sparql/tests/w3c_sparql.rs — Test entry points (all test functions)\n- testsuite-sparql/src/lib.rs — check_testsuite() harness entry point\n- testsuite-sparql/src/manifest.rs — W3C manifest.ttl parsing (TestManifest iterator)\n- testsuite-sparql/src/query_handler.rs — Eval test handler: data load, query exec, result compare\n- testsuite-sparql/src/result_comparison.rs — Isomorphic result comparison (blank node mapping)\n- testsuite-sparql/src/result_format.rs — Parse .srx/.srj/.ttl/.rdf expected results\n- testsuite-sparql/src/report.rs — JSON report generation\n- testsuite-sparql/src/subprocess.rs — Subprocess isolation with timeout enforcement\n- testsuite-sparql/src/bin/run_w3c_test.rs — Subprocess worker binary\n- testsuite-sparql/Makefile — Developer convenience targets\n\nSPARQL pipeline:\n- fluree-db-sparql/src/parser/ — SPARQL parser (grammar rules)\n- fluree-db-sparql/src/lower/ — SPARQL→IR lowering (expression.rs, aggregate.rs, pattern.rs, path.rs, ask.rs, construct.rs, select.rs)\n\nJSON-LD pipeline:\n- fluree-db-query/src/parse/lower.rs — JSON-LD→IR lowering\n\nShared execution:\n- fluree-db-query/src/ir.rs — Shared IR types (Query, Pattern, Expression, etc.)\n- fluree-db-query/src/expression/ — Expression evaluation (string.rs, numeric.rs, etc.)\n- fluree-db-query/src/aggregate.rs — Aggregate function execution\n- fluree-db-query/src/execute.rs — Query execution engine\n\nIntegration tests:\n- fluree-db-api/tests/it_query_sparql.rs — SPARQL integration tests\n- fluree-db-api/tests/it_query.rs — JSON-LD query integration tests\n- fluree-db-api/tests/it_query_analytical.rs — Analytical/grouping JSON-LD tests\n- fluree-db-api/tests/it_query_grouping.rs — GROUP BY JSON-LD tests\n\nDocumentation:\n- docs/contributing/sparql-compliance.md — Full compliance testing guide\n- Cargo.toml line 41-42 — workspace exclude for testsuite-sparql" ;
