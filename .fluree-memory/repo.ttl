mem:fact-01kmqg0w83yereh4ypzr7eqv8b a mem:Fact ;
    mem:content "FLI3 leaf files can legally contain more than 255 leaflets because the format stores `leaflet_count` as u32 and V3 leaf assembly flushes leaves by `leaf_target_rows`, not by leaflet count; POST/PSOT segmentation on `p_id` transitions and OPST segmentation on `o_type` transitions can therefore create many tiny leaflets in one leaf. Read-side cached query paths still key V3 batches by `leaflet_idx: u8`, so when a query scans a leaf whose 257th leaflet is reached it fails with `leaflet index 256 exceeds u8::MAX` (or query-side `leaflet idx exceeds u8`)." ;
    mem:tag "binary-index" ;
    mem:tag "bug" ;
    mem:tag "cache" ;
    mem:tag "leaflet" ;
    mem:tag "query" ;
    mem:tag "v3-cursor" ;
    mem:scope mem:repo ;
    mem:sensitivity "internal" ;
    mem:artifactRef "fluree-db-binary-index/src/format/leaf.rs" ;
    mem:artifactRef "fluree-db-binary-index/src/read/binary_cursor.rs" ;
    mem:artifactRef "fluree-db-binary-index/src/read/leaflet_cache.rs" ;
    mem:createdAt "2026-03-27T11:14:11.331131+00:00"^^xsd:dateTime ;
    mem:factKind "architecture" .

mem:artifact-01kmqgb1can4tedrab6atsbf4h a mem:Artifact ;
    mem:content "Regression coverage for the former >255 leaflet cache-key bug lives in `fluree-db-binary-index/src/read/column_loader.rs` as `cached_loader_supports_leaflet_index_above_255`. The test builds a POST leaf with 257 one-row leaflets by varying `p_id` on every row, then loads leaflet 256 through `load_columns_cached_via_handle` with a `LeafletCache` to verify cached V3 batch loading works beyond the old u8 limit." ;
    mem:tag "binary-index" ;
    mem:tag "cache" ;
    mem:tag "leaflet" ;
    mem:tag "regression-test" ;
    mem:tag "v3-cursor" ;
    mem:scope mem:repo ;
    mem:sensitivity "internal" ;
    mem:artifactRef "fluree-db-binary-index/src/read/column_loader.rs" ;
    mem:createdAt "2026-03-27T11:19:44.266398+00:00"^^xsd:dateTime ;
    mem:artifactKind "file" .

mem:decision-01kmqh7wfsc15dzw6fvkesyza8 a mem:Decision ;
    mem:content "Untyped numeric equality on the V3 binary path now uses a loose encoded prefilter (match by o_key, omit o_type) plus decoded-value equality, instead of forcing `FlakeValue::Long` to `OType::XSD_INTEGER`. This was needed because txn-meta `db:t` values can be stored as `xsd:long`, and exact `o_type` filtering in `binary_range_eq_v3`/`BinaryScanOperator` could miss valid matches." ;
    mem:tag "binary-range" ;
    mem:tag "binary-scan" ;
    mem:tag "commit-t" ;
    mem:tag "datatype" ;
    mem:tag "integer-family" ;
    mem:tag "numeric" ;
    mem:tag "query-correctness" ;
    mem:tag "txn-meta" ;
    mem:scope mem:repo ;
    mem:sensitivity "public" ;
    mem:artifactRef "fluree-db-core/src/range.rs" ;
    mem:artifactRef "fluree-db-query/src/binary_range.rs" ;
    mem:artifactRef "fluree-db-query/src/binary_scan.rs" ;
    mem:createdAt "2026-03-27T11:35:29.529039+00:00"^^xsd:dateTime ;
    mem:rationale "Reuse the existing decoded equality semantics instead of reimplementing datatype-family fanout separately in each binary caller." ;
    mem:alternatives "Predicate-only decode/filter in resolve_t_to_commit_id, stats-driven multi-scan per datatype" .

mem:fact-01kmqhh9n5qtsnjt3f7eq8xf3p a mem:Fact ;
    mem:content "`fluree-db-api/src/graph_query_builder.rs` needs `graph_source_fallback` gated with `#[cfg(feature = \"iceberg\")]` on both the struct field and its constructor initialization. The field is only read inside an `iceberg`-gated fallback path, so leaving it unconditional causes a dead-code warning in default non-iceberg builds." ;
    mem:tag "dead-code" ;
    mem:tag "feature-gating" ;
    mem:tag "fluree-db-api" ;
    mem:tag "graph-query-builder" ;
    mem:tag "iceberg" ;
    mem:tag "r2rml" ;
    mem:tag "warning" ;
    mem:scope mem:repo ;
    mem:sensitivity "internal" ;
    mem:artifactRef "fluree-db-api/src/graph_query_builder.rs" ;
    mem:createdAt "2026-03-27T11:40:37.925049+00:00"^^xsd:dateTime ;
    mem:factKind "configuration" .

