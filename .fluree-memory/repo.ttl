    mem:artifactRef "fluree-db-api/tests/it_ledger_info_reindex_size.rs" ;
    mem:createdAt "2026-03-16T16:02:28.430817+00:00"^^xsd:dateTime .

mem:fact-01km05a22f35014yhvmk8m2ztk a mem:Fact ;
    mem:content "Default-context (and other CAS namespaced blobs) must be stored/fetched under the *canonical* ledger ID (`NsRecord.ledger_id`, e.g. `mydb:main`) because `content_store_for(storage, namespace_id)` and `disconnect_ledger()` use that canonical key. If API methods accept user-provided aliases (`mydb`), do a `nameservice.lookup()` once and use `record.ledger_id` for: content store namespace, config get/push, and cache invalidation; otherwise blobs can be written under `mydb/...` but later looked up under `mydb/main/...` and appear missing, and cache invalidation may fail.\n\nAlso: if writing a new blob *before* a CAS push loop, delete the new blob on final CAS conflict to avoid orphan/leaked objects (best-effort GC)." ;
    mem:tag "cache" ;
    mem:tag "cas" ;
    mem:tag "config" ;
    mem:tag "content-store" ;
    mem:tag "default-context" ;
    mem:tag "gc" ;
    mem:tag "ledger-id" ;
    mem:tag "nameservice" ;
    mem:scope mem:repo ;
    mem:sensitivity "public" ;
    mem:artifactRef "fluree-db-api/src/lib.rs" ;
    mem:artifactRef "fluree-db-core/src/storage.rs" ;
    mem:artifactRef "fluree-db-ledger/src/lib.rs" ;
    mem:createdAt "2026-03-18T09:44:25.935126+00:00"^^xsd:dateTime .

mem:fact-01km06cy17rja09n90v3a50fve a mem:Fact ;
    mem:content "Default-context (and other CAS namespaced blobs) must be stored/fetched under the *canonical* ledger ID (`NsRecord.ledger_id`, e.g. `mydb:main`) because `content_store_for(storage, namespace_id)` and `disconnect_ledger()` use that canonical key. If API methods accept user-provided aliases (`mydb`), do a `nameservice.lookup()` once and use `record.ledger_id` for: content store namespace, config get/push, and cache invalidation; otherwise blobs can be written under `mydb/...` but later looked up under `mydb/main/...` and appear missing, and cache invalidation may fail.\n\nAlso: if writing a new blob *before* a CAS push loop, delete the new blob on final CAS conflict to avoid orphan/leaked objects (best-effort GC)." ;
    mem:tag "cache" ;
